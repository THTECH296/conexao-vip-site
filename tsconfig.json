{
  "compilerOptions": {
    "target": "ES2018",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "js",
    "rootDir": "src",
    "strict": true,
    "noUnusedLocals": true,
    "noImplicitAny": true,
    "removeComments": false,
    "noEmitOnError": false,
    "lib": ["ES2018", "DOM", "DOM.Iterable"]
  },
  "include": ["src/**/*.ts"]
}
